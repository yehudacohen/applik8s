{
  "name": "@applik8s/workspace",
  "private": true,
  "packageManager": "bun@1.3.13",
  "type": "module",
  "workspaces": [
    "packages/applik8s",
    "packages/core",
    "packages/sdk",
    "packages/compiler",
    "packages/runtime-contract",
    "packages/runtime",
    "packages/testing",
    "packages/typekro-adapter",
    "packages/typetainer",
    "packages/e2e",
    "packages/type-tests"
  ],
  "scripts": {
    "generate:runtime-contract": "bun run scripts/generate-runtime-contract.ts",
    "check:runtime-contract": "bun run scripts/check-runtime-contract.ts",
    "check:docs-consistency": "node scripts/check-docs-consistency.mjs",
    "check:local": "node scripts/check-local-gates.mjs",
    "check:prerelease": "node scripts/check-prerelease-gates.mjs",
    "check:release": "node scripts/check-release-readiness.mjs",
    "check:publish-dry-run": "node scripts/package-publish-dry-run.mjs",
    "publish:packages": "node scripts/publish-packages.mjs",
    "applik8s": "bun run packages/applik8s/src/cli.ts",
    "build:imagejob": "bun run applik8s build examples/imagejob.ts --out-dir dist/applik8s",
    "test:imagejob": "bunx vitest run --config vitest.character.config.ts examples/test/product-stories.character.test.ts",
    "test:readme-live": "APPLIK8S_E2E_LIVE=1 bunx vitest run --config vitest.e2e.config.ts packages/e2e/test/readme-imagejob-live.e2e.test.ts",
    "replay:inspect": "node scripts/replay-artifact.mjs",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome lint . && node scripts/check-typecasts.mjs && node scripts/check-static-imports.mjs && node scripts/check-test-taxonomy.mjs && bun run check:runtime-contract && bun run check:docs-consistency && bun run check:release",
    "check:rust": "cargo test --workspace",
    "test": "bun run test:implemented",
    "test:implemented": "vitest run",
    "test:character": "vitest run --config vitest.character.config.ts",
    "test:e2e": "APPLIK8S_E2E=1 vitest run --config vitest.e2e.config.ts",
    "test:e2e:orbstack": "APPLIK8S_E2E=1 APPLIK8S_E2E_CONTEXT=orbstack vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@applik8s/applik8s": "0.1.0",
    "@applik8s/compiler": "0.1.0",
    "@applik8s/core": "0.1.0",
    "@applik8s/sdk": "0.1.0",
    "@applik8s/testing": "0.1.0",
    "@applik8s/typekro-adapter": "0.1.0",
    "@applik8s/typetainer": "0.1.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@kubernetes/client-node": "^1.3.0",
    "arktype": "^2.1.20",
    "commander": "^15.0.0",
    "typekro": "^0.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@bytecodealliance/componentize-js": "^0.21.0",
    "@types/bun": "^1.3.14",
    "esbuild": "^0.28.1",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4",
    "yaml": "^2.9.0"
  }
}
